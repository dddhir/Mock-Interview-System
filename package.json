{
    "name": "ai-mock-interview-rag",
    "version": "1.0.0",
    "description": "AI Mock Interview System with RAG using MERN + Gemini",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "client": "cd client && npm start",
        "server": "nodemon server.js",
        "build": "cd client && npm run build",
        "generate-embeddings": "node scripts/generateEmbeddings.js",
        "startup": "node scripts/startup.js",
        "setup": "npm run startup && npm run start"
    },
    "dependencies": {
        "@google/generative-ai": "^0.24.1",
        "@google-cloud/speech": "^6.0.0",
        "axios": "^1.7.9",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "csv-parser": "^3.0.0",
        "dotenv": "^16.4.7",
        "express": "^4.21.2",
        "jsonwebtoken": "^9.0.2",
        "mammoth": "^1.9.0",
        "mongoose": "^8.9.5",
        "multer": "^1.4.5-lts.1",
        "pdf-parse": "^1.1.1",
        "uuid": "^11.0.5"
    },
    "devDependencies": {
        "nodemon": "^3.1.9"
    }
}